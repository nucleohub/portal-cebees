NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgres://cebees:cebees_dev@localhost:5432/cebees

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me_in_production_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# Encryption for sensitive PII (AES-256)
ENCRYPTION_KEY=change_me_32_bytes_base64_encoded_key_here

# Storage (MinIO in dev, S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin12345
S3_BUCKET=cebees-uploads
S3_FORCE_PATH_STYLE=true

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@cebees.local
SMTP_USER=
SMTP_PASS=

# External providers (stubs in Phase 1)
SENDGRID_API_KEY=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET=

# Observability
LOG_LEVEL=info
SENTRY_DSN=

# CORS
CORS_ORIGIN=http://localhost:5173
